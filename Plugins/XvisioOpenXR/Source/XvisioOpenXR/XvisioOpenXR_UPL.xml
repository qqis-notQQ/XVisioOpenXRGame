	<androidManifestUpdates>
		<setElement result="xvThreeDTag" value="meta-data"/>
		<addAttribute tag="$xvThreeDTag" name="android:name" value="com.xv.THREE_D"/>
		<addAttribute tag="$xvThreeDTag" name="android:value" value="true"/>
		<addElement tag="application" name="xvThreeDTag"/>
	</androidManifestUpdates>
	<!-- optional additions to the GameActivity class in GameActivity.java  -->
	<gameActivityClassAdditions>
		<insert>
			@Override
			public void onWindowFocusChanged (boolean hasFocus) {
			Log.debug("GameActivity onWindowFocusChanged");
			//Because Spaces applications launch on glasses(secondary display) we can ignore focus lost events which allow for
			//keyevents to still be processed by Unreal for remote openxr controllers to function
			if(hasFocus) {
			super.onWindowFocusChanged(hasFocus);
			}
			}

			//Force c++_shared to load before UE4
			static
			{
			System.loadLibrary("c++_shared");
			}
		</insert>
	</gameActivityClassAdditions>

	<gameActivityOnCreateAdditions>
		<if condition="bIsUsingUE5">
			<true>
				<insert>
					PackagedForOculusMobile = true;
				</insert>
			</true>
		</if>
	</gameActivityOnCreateAdditions>
	<buildGradleAdditions>
		<if condition="bLaunchOnViewerAndControllerOnHost">
			<true>
				<insert>
					apply plugin: 'kotlin-android'
				</insert>
			</true>
		</if>
		<insert>
			repositories {
			flatDir{
		</insert>
		<insertValue value="dirs '$S(BuildDir)/libs/'"/>
		<insertNewline/>
		<insert>
			}
			}
			dependencies {
			implementation (name:'libopenxr_loader',ext:'aar')

			}
		</insert>
	</buildGradleAdditions>
</root>